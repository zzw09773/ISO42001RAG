----------------------------------------------------------------
 回滾方式（若內網部署失敗，回到外網 HTTPS gateway 版）
----------------------------------------------------------------

cd ISO42001Deploy
git apply -R intranet_deployment.diff

# 然後手動把 .env 裡的 token 填回去
# 或從備份還原：
tar xzf RAG/data/versions/backup_2026-05-27_073723.tar.gz -C RAG/

