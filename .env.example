# ──────────────────────────────────────────────────────────────────────
# ISO 42001 RAG 系統 — 環境變數範本
# ──────────────────────────────────────────────────────────────────────
# 使用方式：cp .env.example .env，再填入實際值。
# 此範本只含佔位值，不含任何真實金鑰。.env 本身被 .gitignore 排除。
#
# ⚠ 安全強化提示（對應 SYSTEM_ARCHITECTURE_ANALYSIS.md §7 風險登錄）：
#   - 標 [R-INFRA-3] 的帳密務必改為強隨機值，勿沿用預設。
#   - 標 [R-SEC] 的項目影響存取控制，部署前覆核。
# ──────────────────────────────────────────────────────────────────────

# ── 內網 GPU 推論後端（v1.1.0 連線設定）────────────────────────────────
#   LLM：     http://172.16.120.35:7000/v1（vLLM gpt-oss-20b，純 HTTP）
#   Embedding：nv-embed-v2 走 Triton gRPC 172.16.120.35:9001，
#             由 embed-proxy 轉換為 OpenAI /v1/embeddings；rag-api 經 embed-proxy 取得。
LLM_HOST=172.16.120.35                      # 內網推論主機 IP
LLM_PORT=7000                               # LLM HTTP port（openwebui 用）
LLM_API_KEY=internal-dummy-key              # [R-SEC] 內網免金鑰時使用 ASCII dummy，避免 HTTP header 編碼錯誤
LLM_API_BASE=http://172.16.120.35:7000/v1   # ★ rag-api LLM 端點（內網純 HTTP:7000）
CHAT_MODEL_NAME=gpt-oss-20b
VERIFY_SSL=false                            # 純 HTTP 無需驗證；若改 HTTPS CA 憑證才設 true

EMBED_API_KEY=internal-dummy-key            # [R-SEC] embed-proxy 目前不驗證；保留欄位供後續控管
EMBED_API_BASE=http://embed-proxy:7100/v1   # ★ rag-api embed 走 embed-proxy（內部 service）
EMBED_MODEL_NAME=nvidia/NV-embed-V2
EMBED_GRPC_PORT=9001                        # ★ embed-proxy → Triton gRPC port
TRITON_MODEL_NAME=nv-embed-v2               # Triton 上 nv-embed-v2 模型名

# ── PostgreSQL / pgvector ──────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<填入強隨機密碼>           # [R-INFRA-3] 嚴禁沿用預設 postgres；建議 32+ 字元隨機
POSTGRES_DB=Judge
PGVECTOR_URL=postgresql+psycopg://postgres:<同上密碼>@db:5432/Judge

# ── 認證與存取控制（rag-api）───────────────────────────────────────────
# 目前部署基線採內網模式：無金鑰請求以 intranet:<client_ip> 稽核身分放行。
# OPENAI_API_KEYS 是 OpenWebUI 連上游端點用的 connector 值，不是 rag-api 的存取金鑰。
ALLOW_INTRANET_MODE=true                    # [R-SEC] 內網信任邊界；對外暴露時應設 false
OPENAI_API_KEYS=dummy-key;dummy-key          # 兩個 OpenWebUI 上游端點各一值；內網可用 dummy
TRUSTED_PROXIES=127.0.0.1                    # [R-SEC] 僅列實際反代 IP；勿信任整段 Docker/內網 CIDR
ALLOWED_ORIGINS=*                           # [R-SEC-3] CORS；正式環境應限定具體來源而非 *
REACT_MODE=false                            # Agentic ReAct 路徑開關；預設關閉（見架構分析 §2.4）
RERANK_TOP_N=3                              # LLM 重排後保留的文件數
REASONING_EFFORT=low                        # 15 秒互動目標；可改 medium / high 提高推理力度
MAX_RETRIEVAL_TOKENS=3000                   # 注入模型的檢索內容 token 上限
RATE_LIMIT_PER_MINUTE=60                    # 內網模式仍用來源身分進行基本限流
RAG_LOG_LEVEL=INFO
RAG_LOG_VERBOSE=0

# ── 容器執行身分（deploy.sh 自動偵測填入）──────────────────────────────
HOST_UID=1001
HOST_GID=1001
DOCKER_GID=999

# ── 宿主服務 port（避開內網既有 80/443）────────────────────────────────────
NGINX_HTTP_PORT=8088                        # nginx host HTTP port（容器內仍為 80）
NGINX_HTTPS_PORT=8443                       # nginx host HTTPS port（容器內仍為 443）
OPENWEBUI_PORT=18088                        # 直接開 Open WebUI；主要入口仍建議走 nginx HTTPS
KEYCLOAK_PORT=18080                         # Keycloak 管理/登入入口
CODESERVER_PORT=18443                       # code-server Web IDE
JUPYTER_PORT=25678                          # Jupyter host port（容器內 8888）
WEBUI_URL=https://aimla.ai.example.com:8443
WEBUI_SECRET_KEY=<填入強隨機值>              # [R-SEC] openwebui session 簽章；勿用預設 your-secret-key-here

# ── OpenWebUI / Keycloak OIDC ──────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=<填入強隨機密碼>
OAUTH_PROVIDER_NAME=Keycloak
OAUTH_CLIENT_ID=openwebui
OAUTH_CLIENT_SECRET=openwebui-dev-client-secret-change-me
OPENID_PROVIDER_URL=http://keycloak:8080/realms/iso42001/.well-known/openid-configuration
OAUTH_SCOPES=openid email profile
ENABLE_OAUTH_SIGNUP=true
OAUTH_MERGE_ACCOUNTS_BY_EMAIL=true

# ── Code Server ────────────────────────────────────────────────────────
CODESERVER_PASSWORD=<填入強隨機密碼>
CODESERVER_SUDO_PASSWORD=<填入強隨機密碼>

# ── Admin Console（憑證卡優先；直接 port 僅限受控內網）──────────────────
ADMIN_PORT=8300
# 逗號分隔的憑證 subject serialNumber（員工編號）；至少設定一筆，否則 admin fail-closed。
ADMIN_CARD_SERIALS=
# 緊急帳密登入預設關閉；只有明確啟用時才需填下列兩欄。
ENABLE_PASSWORD_FALLBACK=false
ADMIN_USERNAME=
ADMIN_PASSWORD=

# ── 索引參數 ───────────────────────────────────────────────────────────
CHUNK_SIZE=1000
TOP_K=5

# ── 漂移偵測暖機（monitoring_addon）────────────────────────────────────
# 內網初期：drift_baseline 是 LLM 模擬，真實查詢會被誤判漂移 → 維持 false（暖機，
# 只計算/顯示不告警）。累積足夠真實查詢後，用 build_drift_baseline.py
# --from-audit-logs 從真實 audit log 重建基線，再改 true 開啟告警。
DRIFT_ALARM_ENABLED=false
MIN_DRIFT_SAMPLE=100                        # PSI/JSD 最小樣本數（低於此判 insufficient_data）

# ── 監測告警迴圈（monitoring_addon）────────────────────────────────────
ALERT_ANOMALY_INTERVAL_SEC=300             # 異常檢查週期（秒）
ALERT_DRIFT_INTERVAL_SEC=900               # 漂移檢查週期
ALERT_INTEGRITY_INTERVAL_SEC=3600          # 雜湊鏈完整性檢查週期
ALERT_DEDUP_WINDOW_SEC=600                 # 告警去重視窗

# ── 告警 SMTP（可選；host 留空則只寫 alerts.jsonl 不寄信）──────────────
ALERT_SMTP_HOST=                           # 內網 SMTP relay；留空停用郵件告警
ALERT_SMTP_PORT=25
ALERT_SMTP_USER=
ALERT_SMTP_PASS=                           # [R-SEC] 勿提交至版控
ALERT_SMTP_FROM=monitoring@iso42001.local
ALERT_SMTP_USE_TLS=false
ALERT_RECIPIENTS=                          # 逗號分隔收件人
